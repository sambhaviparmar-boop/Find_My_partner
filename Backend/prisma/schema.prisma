generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  refreshToken  String?
  isBlacklisted Boolean        @default(false)

  // Profile
  profile       Profile?

  // Builder Passport
  builderPassport BuilderPassport?

  // Skills
  userSkills    UserSkill[]

  // Preference
  preference    UserPreference?

  // Matching
  sentMatches     Match[] @relation("SenderMatch")
  receivedMatches Match[] @relation("ReceiverMatch")

  // Connections
  sentConnections     Connection[] @relation("ConnectionSender")
  receivedConnections Connection[] @relation("ConnectionReceiver")

  // Chat
  sentChats     Chat[] @relation("ChatSender")
  receivedChats Chat[] @relation("ChatReceiver")

  sentMessages  Message[] @relation("MessageSender")

  // Teams
  teamsOwned      Team[] @relation("TeamOwner")
  teamMemberships TeamMember[]

  // Team Invitations
  sentInvitations     TeamInvitation[] @relation("InvitationSender")
  receivedInvitations TeamInvitation[] @relation("InvitationReceiver")

  // Groups
  ownedGroups   Group[]       @relation("GroupOwner")
  joinedGroups  GroupMember[]
  joinRequests  JoinRequest[]

  // Hackathons
  createdHackathons Hackathon[] @relation("HackathonCreator")

  // Notifications
  notifications Notification[]

  // Reliability
  reliabilities Reliability[]

  // Saved Partners
  savedPartners     SavedPartner[] @relation("SavedBy")
  savedByPartners   SavedPartner[] @relation("SavedUser")

  // Search History
  searchHistory     SearchHistory[]

  // Reports
  reportedUsers     Report[] @relation("Reporter")
  reportsAgainstMe  Report[] @relation("ReportedUser")

  // Blocks
  blockedUsers      Block[]  @relation("Blocker")
  blockedByUsers    Block[]  @relation("BlockedUser")

  // Reviews
  givenReviews      Review[] @relation("Reviewer")
  receivedReviews   Review[] @relation("ReviewedUser")

  // Domain profiles
  networkingProfile NetworkingProfile?
  shoppingPreference ShoppingPreference?
  datingProfile DatingProfile?

  // Uploads
  uploads Upload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reliability {
  id                      Int                 @id @default(autoincrement())
  userId                  Int
  category                ReliabilityCategory
  score                   Float               @default(0)
  totalConnections        Int                 @default(0)
  successfulConnections   Int                 @default(0)
  completedCollaborations Int                 @default(0)
  responseRate            Float               @default(0)
  reviewsCount            Int                 @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
}

enum ReliabilityCategory {
  HACKATHON
  STARTUP
  FITNESS
  STUDY
  SHOPPING
  TRAVEL
  DATING
}

model Group {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  vertical    String
  maxMembers  Int
  isPublic    Boolean       @default(true)
  ownerId     Int
  owner       User          @relation("GroupOwner", fields: [ownerId], references: [id])
  joinRequests JoinRequest[]
  members     GroupMember[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model JoinRequest {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  status    String   @default("PENDING")
  message   String?

  group     Group    @relation(fields: [groupId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, userId])
}

model Profile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  bio         String?
  avatar      String?
  phone       String?
  college     String?
  branch      String?
  year        Int?
  company     String?
  designation String?
  city        String?
  state       String?
  country     String?
  latitude    Float?
  longitude   Float?
  github      String?
  linkedin    String?
  portfolio   String?
  website     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id        Int         @id @default(autoincrement())
  name      String
  category  String
  createdAt DateTime    @default(now())
  userSkills UserSkill[]
}

model UserSkill {
  id         Int      @id @default(autoincrement())
  userId     Int
  skillId    Int
  level      String
  experience Int?

  user  User  @relation(fields: [userId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model BuilderPassport {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  github          String?
  linkedin        String?
  leetcode        String?
  codeforces      String?
  portfolio       String?
  githubScore     Int      @default(0)
  leetcodeScore   Int      @default(0)
  codeforcesScore Int      @default(0)
  totalScore      Int      @default(0)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id         Int         @id @default(autoincrement())
  senderId   Int
  receiverId Int
  category   String
  matchScore Float
  status     MatchStatus @default(RECOMMENDED)
  reason     Json?

  sender   User @relation("SenderMatch", fields: [senderId], references: [id])
  receiver User @relation("ReceiverMatch", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId, category])
}

enum MatchStatus {
  RECOMMENDED
  INTERESTED
  CONNECTED
  REJECTED
}

enum GroupRole {
  OWNER
  MEMBER
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum Vertical {
  WEB
  APP
  AI_ML
  BLOCKCHAIN
  CYBERSECURITY
  CLOUD
  IOT
}

model Team {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  ownerId     Int
  owner       User             @relation("TeamOwner", fields: [ownerId], references: [id])
  members     TeamMember[]
  invitations TeamInvitation[]
  hackathonId Int?
  hackathon   Hackathon?       @relation(fields: [hackathonId], references: [id])
  maxMembers  Int              @default(4)
  workspace   Workspace?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId    Int
  userId    Int
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

model Hackathon {
  id                   Int      @id @default(autoincrement())
  title                String
  description          String?
  organizer            String
  mode                 String // ONLINE | OFFLINE | HYBRID
  location             String?
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime
  maxTeamSize          Int
  prizePool            String?
  website              String?
  image                String?
  status               String   @default("UPCOMING")
  createdBy            Int

  creator User @relation("HackathonCreator", fields: [createdBy], references: [id])

  teams Team[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamInvitation {
  id         Int              @id @default(autoincrement())
  teamId     Int
  senderId   Int
  receiverId Int
  status     InvitationStatus @default(PENDING)
  message    String?

  team     Team @relation(fields: [teamId], references: [id])
  sender   User @relation("InvitationSender", fields: [senderId], references: [id])
  receiver User @relation("InvitationReceiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, receiverId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model Workspace {
  id          Int     @id @default(autoincrement())
  teamId      Int     @unique
  githubRepo  String?
  meetingLink String?
  description String?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPreference {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  category           String
  lookingFor         String
  skillsNeeded       String?
  interests          String[]
  locationPreference String?
  maxDistance        Int? // in KM
  isPublic           Boolean  @default(true)
  isRemoteAllowed    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NetworkingProfile {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  industry    String?
  currentRole String?
  experience  Int?
  goals       String?
  availability String?
  location    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShoppingPreference {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  categories         String[]
  budgetRange        String?
  shoppingType       String?
  preferredLocation  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DatingProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  bio        String?
  interests  String[]
  gender     String?
  location   String?
  ageRange   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Upload {
  id        Int      @id @default(autoincrement())
  userId    Int
  url       String
  publicId  String
  type      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Connection {
  id         Int              @id @default(autoincrement())
  senderId   Int
  receiverId Int
  category   String
  status     ConnectionStatus @default(PENDING)
  message    String?

  sender   User @relation("ConnectionSender", fields: [senderId], references: [id])
  receiver User @relation("ConnectionReceiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId, category])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Chat {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int

  sender   User @relation("ChatSender", fields: [senderId], references: [id])
  receiver User @relation("ChatReceiver", fields: [receiverId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId])
}

model Message {
  id          Int       @id @default(autoincrement())
  chatId      Int
  senderId    Int
  content     String
  isRead      Boolean   @default(false)
  deliveredAt DateTime?
  seenAt      DateTime?
  updatedAt   DateTime  @updatedAt @default(now())
  createdAt   DateTime  @default(now())

  chat   Chat @relation(fields: [chatId], references: [id])
  sender User @relation("MessageSender", fields: [senderId], references: [id])
}

model Notification {
  id          Int              @id @default(autoincrement())
  userId      Int
  title       String
  message     String
  type        NotificationType
  isRead      Boolean          @default(false)
  referenceId Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum NotificationType {
  MATCH
  CONNECTION
  MESSAGE
  TEAM_INVITATION
  TASK
  HACKATHON
  SYSTEM
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  query     String?
  category  String?
  filters   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model SavedPartner {
  id          Int      @id @default(autoincrement())
  userId      Int
  savedUserId Int

  user      User @relation("SavedBy", fields: [userId], references: [id])
  savedUser User @relation("SavedUser", fields: [savedUserId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, savedUserId])
}

model Review {
  id             Int            @id @default(autoincrement())
  reviewerId     Int
  reviewedUserId Int
  category       ReviewCategory
  rating         Int
  comment        String?
  connectionId   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewer     User @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewedUser User @relation("ReviewedUser", fields: [reviewedUserId], references: [id])

  @@unique([reviewerId, reviewedUserId, category])
}

enum ReviewCategory {
  HACKATHON
  STARTUP
  FITNESS
  STUDY
  SHOPPING
  TRAVEL
  DATING
}

model Report {
  id             Int          @id @default(autoincrement())
  reporterId     Int
  reportedUserId Int
  reason         String
  description    String?
  status         ReportStatus @default(PENDING)

  reporter     User @relation("Reporter", fields: [reporterId], references: [id])
  reportedUser User @relation("ReportedUser", fields: [reportedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReportStatus {
  PENDING
  REVIEWED
  REJECTED
}

model Block {
  id            Int      @id @default(autoincrement())
  blockerId     Int
  blockedUserId Int

  blocker     User @relation("Blocker", fields: [blockerId], references: [id])
  blockedUser User @relation("BlockedUser", fields: [blockedUserId], references: [id])

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedUserId])
}
